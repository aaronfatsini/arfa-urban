---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ARFA Studios | Fotografía Inmobiliaria y Dron en Tarragona">
	<main>
    <!-- Header / Nav Placeholder -->
    <nav class="fixed top-0 w-full z-50 px-8 py-6 flex justify-between items-center mix-blend-difference">
      <div class="flex items-center gap-2">
        <!-- Espacio para el Isotipo -->
        <div class="w-8 h-8 bg-white rounded-sm transform -skew-x-12 flex items-center justify-center font-black text-black italic">A</div>
        <span class="font-black text-xl tracking-tighter uppercase">ARFA Studios</span>
      </div>
      <a href="#contacto" class="text-sm font-bold uppercase tracking-widest border-b border-white hover:text-yellow-400 hover:border-yellow-400 transition-colors">Contacto</a>
    </nav>
		
    <!-- Hero Section -->
    <header class="min-h-screen flex flex-col justify-end p-8 md:p-16 border-b border-white/10 relative overflow-hidden">
      <!-- Background subtle effect -->
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=60&w=1600')] bg-cover bg-center opacity-20 grayscale"></div>
      
      <div class="relative z-10 animate-slide-up">
        <h2 class="text-xl font-bold tracking-tighter text-yellow-400 mb-4">// ARFA STUDIOS</h2>
        <h1 class="text-7xl md:text-[10rem] font-black leading-[0.85] tracking-tighter mb-12 uppercase">
          Kill <br/>The <br/>Ordinary.
        </h1>
        <div class="flex flex-col md:flex-row justify-between items-end gap-8">
           <p class="text-xl md:text-2xl text-gray-400 max-w-2xl font-medium leading-tight">
            Deja de hacer scroll. Empieza a vender. <br/>
            Contenido visual de alto impacto para el sector inmobiliario moderno en Tarragona y alrededores.
          </p>
          <a href="#contacto" class="group relative inline-block text-3xl font-black uppercase tracking-tighter shrink-0">
            <span class="relative z-10">Contáctanos →</span>
            <div class="absolute bottom-0 left-0 w-full h-4 bg-yellow-400 group-hover:h-full transition-all duration-300 -z-10"></div>
          </a>
        </div>
      </div>
    </header>

    <!-- Value Prop: 3 Pillars -->
    <section class="grid grid-cols-1 md:grid-cols-3 border-b border-white/10">
      <div class="p-8 md:p-12 border-b md:border-b-0 md:border-r border-white/10 flex flex-col gap-4">
        <span class="text-yellow-400 font-bold text-lg">01/</span>
        <h3 class="text-3xl font-black uppercase">Entrega en 48h</h3>
        <p class="text-gray-400">Sabemos que el tiempo es dinero. Tu material listo para publicar en dos días hábiles.</p>
      </div>
      <div class="p-8 md:p-12 border-b md:border-b-0 md:border-r border-white/10 flex flex-col gap-4">
        <span class="text-yellow-400 font-bold text-lg">02/</span>
        <h3 class="text-3xl font-black uppercase">Dron Legal</h3>
        <p class="text-gray-400">Operadores certificados por AESA con seguro de responsabilidad civil. Vuelo seguro y profesional.</p>
      </div>
      <div class="p-8 md:p-12 flex flex-col gap-4">
        <span class="text-yellow-400 font-bold text-lg">03/</span>
        <h3 class="text-3xl font-black uppercase">Foto HDR Pro</h3>
        <p class="text-gray-400">Fotografía técnica de alto rango dinámico para capturar cada detalle de luz en interiores.</p>
      </div>
    </section>

    <!-- Portfolio: Robust Grid -->
    <section id="portfolio" class="p-4 md:p-8 border-b border-white/10">
        <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
            <div class="portfolio-item overflow-hidden rounded-xl bg-zinc-900 aspect-video md:aspect-square">
              <img src="https://images.unsplash.com/photo-1600607687940-4e524cb35d3a?auto=format&fit=crop&q=80&w=1000" class="portfolio-img w-full h-full object-cover transition-all duration-700" alt="Vista Aérea" />
            </div>
            <div class="portfolio-item overflow-hidden rounded-xl bg-zinc-900 aspect-square">
              <img src="https://images.pexels.com/photos/2724748/pexels-photo-2724748.jpeg?auto=compress&cs=tinysrgb&w=1000" class="portfolio-img w-full h-full object-cover transition-all duration-700" alt="Interior" />
            </div>
            <div class="portfolio-item overflow-hidden rounded-xl bg-zinc-900 aspect-[4/5]">
              <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&q=80&w=1000" class="portfolio-img w-full h-full object-cover transition-all duration-700" alt="Propiedad de Lujo" />
            </div>
            <div class="portfolio-item overflow-hidden rounded-xl bg-zinc-900 aspect-video">
               <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80&w=1000" class="portfolio-img w-full h-full object-cover transition-all duration-700" alt="Salón Moderno" />
            </div>
        </div>
    </section>

    <!-- Services: Industrial Grid -->
    <section class="grid grid-cols-1 md:grid-cols-2 border-b border-white/10">
        <div class="p-8 md:p-16 border-b md:border-b-0 md:border-r border-white/10 hover:bg-white/[0.02] transition-colors group">
            <span class="text-6xl font-black text-white/10 group-hover:text-yellow-400/20 transition-colors">PACK</span>
            <h3 class="text-5xl font-black uppercase mt-4 mb-6">Básico</h3>
            <ul class="space-y-3 text-gray-400 text-xl mb-8 font-light">
                <li><span class="text-yellow-400">●</span> 15 Fotos de alta resolución</li>
                <li><span class="text-yellow-400">●</span> Retoque profesional HDR</li>
                <li><span class="text-yellow-400">●</span> Corrección de perspectiva</li>
                <li><span class="text-yellow-400">●</span> Entrega en 48 horas</li>
            </ul>
            <div class="text-6xl font-black">150€</div>
        </div>
        <div class="p-8 md:p-16 hover:bg-white/[0.02] transition-colors group bg-zinc-900/30">
            <span class="text-6xl font-black text-white/10 group-hover:text-yellow-400/20 transition-colors">PACK</span>
            <h3 class="text-5xl font-black uppercase mt-4 mb-6">Completo</h3>
            <ul class="space-y-3 text-gray-400 text-xl mb-8 font-light">
                <li><span class="text-yellow-400">●</span> Fotografía Interior y Exterior</li>
                <li><span class="text-yellow-400">●</span> 5 Tomas aéreas (Dron)</li>
                <li><span class="text-yellow-400">●</span> Reel vertical 60 segundos</li>
                <li><span class="text-yellow-400">●</span> Entrega en 48 horas</li>
            </ul>
            <div class="text-6xl font-black text-yellow-400">200€</div>
        </div>
    </section>

    <!-- Methodology: 1-2-3 -->
    <section class="py-24 px-8 md:px-16 border-b border-white/10">
      <h2 class="text-4xl font-black uppercase mb-16 text-center">Garantía ARFA: <span class="text-yellow-400">3 Pasos</span></h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="text-center">
          <div class="text-8xl font-black opacity-10 mb-4">01</div>
          <h4 class="text-2xl font-bold uppercase mb-2">Agendamos</h4>
          <p class="text-gray-500">Contacto rápido y reserva de fecha según tu disponibilidad.</p>
        </div>
        <div class="text-center">
          <div class="text-8xl font-black opacity-10 mb-4">02</div>
          <h4 class="text-2xl font-bold uppercase mb-2">Capturamos</h4>
          <p class="text-gray-500">Sesión técnica optimizada: entramos, volamos y disparamos.</p>
        </div>
        <div class="text-center">
          <div class="text-8xl font-black opacity-10 mb-4">03</div>
          <h4 class="text-2xl font-bold uppercase mb-2">Vendes</h4>
          <p class="text-gray-500">En 48h recibes el material listo para subir a portales y redes.</p>
        </div>
      </div>
    </section>

    <!-- Footer / Contact -->
    <footer id="contacto" class="bg-yellow-400 text-black p-8 md:p-24 text-center">
        <h2 class="text-5xl md:text-9xl font-black uppercase tracking-tighter mb-8 italic">Let's work.</h2>
        <div class="flex flex-col items-center gap-6">
          <p class="text-xl font-bold uppercase tracking-widest">¿Hablamos del próximo proyecto?</p>
          <a href="#" class="text-3xl md:text-5xl font-black border-b-8 border-black hover:bg-black hover:text-white transition-all px-6 py-2">WHATSAPP</a>
        </div>
        <p class="mt-20 font-bold uppercase tracking-widest text-xs opacity-60">© 2026 ARFA STUDIOS / SIN LÍMITES</p>
    </footer>

	</main>
</Layout>

<style>
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(60px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-slide-up {
    animation: slide-up 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Lógica de color en móviles vs desktop */
  @media (hover: hover) {
    .portfolio-img {
      filter: grayscale(100%);
    }
    .portfolio-item:hover .portfolio-img {
      filter: grayscale(0%);
      transform: scale(1.05);
    }
  }
</style>
