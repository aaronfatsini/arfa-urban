---
import '../styles/global.css'

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/ARFA STUDIOS BLANC EN SOMBRA.png" />
		<meta name="generator" content={Astro.generator} />
    <meta name="description" content="Servicios profesionales de fotografía inmobiliaria, vídeo y tomas aéreas en Tarragona y alrededores. Entrega en 48 horas." />
		<title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0a0a0a] text-white font-['Inter'] selection:bg-yellow-400 selection:text-black">
		<slot />
	</body>
</html>

<style is:global>
	html {
		font-family: 'Inter', system-ui, sans-serif;
		background: #0a0a0a;
    scroll-behavior: smooth;
	}
  /* Estilo para ocultar scrollbars pero permitir scroll funcional */
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
