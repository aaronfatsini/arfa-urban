---
import '../styles/global.css'

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon-rounded.png" />
    <link rel="apple-touch-icon" href="/favicon-rounded.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Fotografía inmobiliaria profesional, vídeo 4K y dron legal para el sector inmobiliario. Entrega en 48 h en Tarragona, Costa Daurada y alrededores." />
		<title>{title || "ARFA Studios | Fotografía y vídeo inmobiliario en Tarragona"}</title>
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ARFA Studios" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:title" content={title || "ARFA Studios | Fotografía y vídeo inmobiliario en Tarragona"} />
    <meta property="og:description" content="Fotografía inmobiliaria profesional, vídeo 4K y dron legal para el sector inmobiliario. Entrega en 48 h en Tarragona, Costa Daurada y alrededores." />
    <meta property="og:image" content="/favicon-rounded.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="twitter:title" content={title || "ARFA Studios | Fotografía y vídeo inmobiliario en Tarragona"} />
    <meta property="twitter:description" content="Fotografía inmobiliaria profesional, vídeo 4K y dron legal para el sector inmobiliario. Entrega en 48 h en Tarragona, Costa Daurada y alrededores." />
    <meta property="twitter:image" content="/favicon-rounded.png" />

    <!-- Schema JSON-LD -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "ARFA Studios",
        "url": "https://www.arfastudios.com",
        "image": "https://www.arfastudios.com/favicon-rounded.png",
        "areaServed": ["Tarragona", "Costa Daurada", "Delta del Ebro", "Vinaròs"],
        "description": "Fotografía inmobiliaria profesional, vídeo 4K y dron legal.",
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Servicios inmobiliarios",
          "itemListElement": [
            { "@type": "Service", "name": "fotografía inmobiliaria" },
            { "@type": "Service", "name": "vídeo 4K" },
            { "@type": "Service", "name": "dron legal" }
          ]
        }
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0a0a0a] text-white font-['Inter'] selection:bg-yellow-400 selection:text-black">
		<slot />
	</body>
</html>

<style is:global>
	html {
		font-family: 'Inter', system-ui, sans-serif;
		background: #0a0a0a;
    scroll-behavior: smooth;
	}
  /* Estilo para ocultar scrollbars pero permitir scroll funcional */
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
