---
import '../styles/global.css'

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/ARFA STUDIOS BLANC EN SOMBRA.png" />
		<meta name="generator" content={Astro.generator} />
    <meta name="description" content="Fotografía inmobiliaria profesional, vídeo 4K y dron legal para inmobiliarias y alquiler vacacional. Entrega en 48 h. Tarragona y alrededores." />
		<title>{title}</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://arfastudios.com/" />
    <meta property="og:title" content="ARFA Studios | Fotografía Inmobiliaria en Tarragona" />
    <meta property="og:description" content="Fotografía inmobiliaria profesional, vídeo 4K y dron legal para inmobiliarias y alquiler vacacional. Entrega en 48 h. Tarragona y alrededores." />
    <meta property="og:image" content="https://arfastudios.com/og-image.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://arfastudios.com/" />
    <meta property="twitter:title" content="ARFA Studios | Fotografía Inmobiliaria en Tarragona" />
    <meta property="twitter:description" content="Fotografía inmobiliaria profesional, vídeo 4K y dron legal para inmobiliarias y alquiler vacacional. Entrega en 48 h. Tarragona y alrededores." />
    <meta property="twitter:image" content="https://arfastudios.com/og-image.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0a0a0a] text-white font-['Inter'] selection:bg-yellow-400 selection:text-black">
		<slot />
	</body>
</html>

<style is:global>
	html {
		font-family: 'Inter', system-ui, sans-serif;
		background: #0a0a0a;
    scroll-behavior: smooth;
	}
  /* Estilo para ocultar scrollbars pero permitir scroll funcional */
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
